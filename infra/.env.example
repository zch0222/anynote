# ============================================================
# Anynote Docker Compose 环境变量
# 使用方法：cp .env.example .env，然后修改 .env 中的值
# .env 已被 .gitignore 忽略，不会提交到版本库
# ============================================================

# -------- 必须修改（生产/对外暴露环境）--------

# JWT 签名密钥，建议使用随机字符串（至少 32 位）
# 生成命令：openssl rand -hex 32
JWT_SECRET=yxlm

# XXL-Job 执行器与调度中心通信 Token
XXL_JOB_ADMIN_ACCESSTOKEN=default_token

# MySQL root 密码（Nacos、XXL-Job 初始化使用）
MYSQL_ROOT_PASSWORD=AnynoteRoot123

# MySQL 应用账户密码（所有微服务使用）
MYSQL_APP_PASSWORD=Anynote*1832

# MinIO 对象存储密码
MINIO_ROOT_PASSWORD=AnynoteMinio123

# Redis 密码（留空表示不启用认证）
REDIS_PASSWORD=

# -------- 可选修改 --------

# MySQL 应用账户名
MYSQL_APP_USER=anynote

# 数据库名
MYSQL_DATABASE=anynote

# MinIO 用户名
MINIO_ROOT_USER=anynote

# Nacos 命名空间 ID
NACOS_NAMESPACE=0587fa28-1301-43db-a7a1-599c00fc3f70

# Spring Profile（dev / prod）
SPRING_PROFILES_ACTIVE=dev

# JVM 参数
JAVA_OPTS=-Xms256m -Xmx512m

# Python AI 服务地址（宿主机运行时默认值即可）
AI_FASTAPI_ADDRESS=http://host.docker.internal:8000
