# ============================================================
# Anynote IDEA / 本机 Java 开发环境变量样板
#
# 用途：当 9 个 Java 服务在 **IDEA 或 mvn spring-boot:run 直接在宿主机
# 运行**（不是在 docker 容器里跑）时，需要把中间件 host 重定向到
# 127.0.0.1（因为容器端口 publish 到 127.0.0.1 而不是容器名）。
#
# 使用方法：
#   1. cp infra/.env.idea.example infra/.env.idea
#   2. 在 IDEA Run Configuration → Environment Variables 中导入该文件，
#      或在 shell 里 `set -a; . infra/.env.idea; set +a` 后启动服务
#
# ⚠️ 重要：本文件 **绝对不要被 docker compose 读取**。如果它被自动加
#    载（命名为 .env），里面的 127.0.0.1 会注入到容器，破坏 RocketMQ
#    broker 自我广播等关键行为。因此：
#    - 文件名严格保留为 .env.idea（不要重命名为 .env）
#    - docker compose 命令统一加 `--env-file=/dev/null`（详见 README）
#
# 与 infra/.env.example 的关系：
#    - infra/.env.example       → 部署 / 容器化用，密码、镜像 tag 等
#    - infra/.env.idea.example  → IDEA 本机开发用，host 重定向
# ============================================================

# 中间件 host 重定向（所有中间件通过 docker compose 启动并发布到 127.0.0.1）
MYSQL_HOST=127.0.0.1
REDIS_HOST=127.0.0.1
ELASTICSEARCH_HOST=127.0.0.1
ROCKETMQ_NAME_SERVER=127.0.0.1:9876

# RocketMQ broker 自我广播地址（IDEA 跑 Java 时需指向宿主机回环）
ROCKETMQ_BROKER_ADVERTISE_IP=127.0.0.1

# JWT 签名密钥（开发可用默认弱值，生产参考 .env.example）
JWT_SECRET=yxlm
