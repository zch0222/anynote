{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "check": {
      "outputs": []
    },
    "openapi:generate": {
      "dependsOn": [],
      "outputs": ["packages/api-client/src/**"]
    },
    "typecheck": {
      "outputs": []
    }
  }
}
